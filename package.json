{
  "name": "@kubohiroya/tmpose-kamishibai",
  "version": "3.1.0",
  "private": false,
  "type": "module",
  "description": "TMPose紙芝居 — ポーズで進めるAIインタラクティブ紙芝居",
  "homepage": "https://kubohiroya.github.io/tmpose-kamishibai/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kubohiroya/tmpose-kamishibai.git"
  },
  "exports": {
    "./builder": "./src/builder/index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "tmpose-kamishibai": "./bin/tmpose-kamishibai.mjs"
  },
  "files": [
    "bin/",
    "src/builder/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "sb3:build": "node scripts/sb3/build.mjs",
    "sb3:check": "node scripts/sb3/check.mjs",
    "sb3:import": "node scripts/sb3/import.mjs",
    "lint": "eslint src/builder bin test/builder.test.mjs",
    "format": "prettier --check package.json src/builder bin test/builder.test.mjs docs/general/06-developer-guide.md README.md",
    "typecheck": "tsc --project tsconfig.builder.json",
    "preview:docs": "vivliostyle preview --config docs/vivliostyle.general.config.mjs",
    "preview:staff": "vivliostyle preview --config docs/vivliostyle.staff.config.mjs",
    "preview:workshop": "vivliostyle preview --config docs/vivliostyle.workshop.config.mjs",
    "pretest": "node scripts/sb3/prepare-test.mjs",
    "test": "node --test test/*.test.mjs",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "prepack": "pnpm lint && pnpm format && pnpm typecheck && node --test test/builder.test.mjs",
    "tmpose-kamishibai": "node bin/tmpose-kamishibai.mjs"
  },
  "keywords": [
    "turbowarp",
    "scratch",
    "teachable-machine",
    "pose-recognition",
    "kamishibai"
  ],
  "author": "Hiroya Kubo",
  "license": "MIT",
  "dependencies": {
    "fflate": "0.8.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@turbowarp/scratch-svg-renderer": "1.1.0",
    "@vivliostyle/cli": "11.1.0",
    "eslint": "^9.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.0.0",
    "rubygana": "github:kubohiroya/rubygana#a24b8a699a1b033546f4d1a47a63005f7af95735",
    "scratch-parser": "6.0.0",
    "scratch-render-fonts": "github:TurboWarp/scratch-render-fonts#7b6768fc6dfef6b343a06f992587b74807043961",
    "scratch-vm": "github:TurboWarp/scratch-vm#c4823421cb7c17d8d8a89878851ce1668c26a21f",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
